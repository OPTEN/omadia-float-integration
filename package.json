{
  "name": "omadia-float-integration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Omadia integration plugin for Float (float.com): read-only access to people, projects, allocations, time off and clients.",
  "license": "MIT",
  "homepage": "https://github.com/OPTEN/omadia-float-integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/OPTEN/omadia-float-integration.git"
  },
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:float": "npm run build -w examples/float-integration",
    "build:channel": "npm run build -w examples/channel",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
